{
  "name": "a11ylens",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence-first accessibility audits for modern web applications.",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc -b && vite build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axe-core": "^4.12.1",
    "express": "^5.2.1",
    "lucide-react": "^1.23.0",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
